generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid()) @map("_id")
  name      String
  email     String   @unique
  password  String
  role      String   @default("MEMBER")
  createdAt DateTime @default(now())
}

model Project {
  id          String   @id @default(cuid()) @map("_id")
  name        String
  description String?
  createdAt   DateTime @default(now())
  createdBy   String
}

model ProjectMember {
  id        String   @id @default(cuid()) @map("_id")
  role      String   @default("MEMBER")
  createdAt DateTime @default(now())
  projectId String
  userId    String
}

model Task {
  id          String    @id @default(cuid()) @map("_id")
  title       String
  description String?
  status      String    @default("TODO")
  priority    String    @default("MEDIUM")
  dueDate     DateTime?
  createdAt   DateTime  @default(now())
  projectId   String
  assigneeId  String?
  createdById String
}

model TaskFile {
  id           String   @id @default(cuid()) @map("_id")
  name         String
  size         Int
  type         String
  path         String
  createdAt    DateTime @default(now())
  taskId       String
  uploadedById String
}

model ActivityLog {
  id        String   @id @default(cuid()) @map("_id")
  action    String
  entity    String
  entityId  String?
  details   String?
  createdAt DateTime @default(now())
  userId    String
}

model TaskComment {
  id        String   @id @default(cuid()) @map("_id")
  content   String
  createdAt DateTime @default(now())
  taskId    String
  userId    String
}

model SubTask {
  id        String   @id @default(cuid()) @map("_id")
  title     String
  completed Boolean  @default(false)
  createdAt DateTime @default(now())
  taskId    String
}

model Label {
  id        String   @id @default(cuid()) @map("_id")
  name      String
  color     String   @default("#6366f1")
  createdAt DateTime @default(now())
  projectId String
}

model TaskLabel {
  id      String @id @default(cuid()) @map("_id")
  taskId  String
  labelId String
}

model Notification {
  id        String   @id @default(cuid()) @map("_id")
  type      String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  userId    String
  taskId    String?
}

model TaskDependency {
  id          String @id @default(cuid()) @map("_id")
  dependentId String
  dependsOnId String
}

model TimeEntry {
  id          String   @id @default(cuid()) @map("_id")
  hours       Float
  description String?
  createdAt   DateTime @default(now())
  taskId      String
  userId      String
}

model TaskWatcher {
  id        String   @id @default(cuid()) @map("_id")
  createdAt DateTime @default(now())
  taskId    String
  userId    String
}

model Phase {
  id          String   @id @default(cuid()) @map("_id")
  name        String
  description String?
  startDate   DateTime?
  endDate     DateTime?
  status      String   @default("PLANNED")
  createdAt   DateTime @default(now())
  projectId   String
}

model Issue {
  id          String    @id @default(cuid()) @map("_id")
  title       String
  description String?
  status      String    @default("OPEN")
  priority    String    @default("MEDIUM")
  severity    String    @default("MAJOR")
  dueDate     DateTime?
  createdAt   DateTime  @default(now())
  projectId   String
  assigneeId  String?
  reporterId  String
}

model ProjectDocument {
  id           String   @id @default(cuid()) @map("_id")
  name         String
  size         Int
  type         String
  path         String
  createdAt    DateTime @default(now())
  projectId    String
  uploadedById String
}

model ResourceLink {
  id          String   @id @default(cuid()) @map("_id")
  url         String
  title       String
  description String?
  createdAt   DateTime @default(now())
  projectId   String?
  taskId      String?
  createdById String
}

model Conversation {
  id              String   @id @default(cuid()) @map("_id")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  participant1Id  String
  participant2Id  String
}

model ChatMessage {
  id              String   @id @default(cuid()) @map("_id")
  content         String
  createdAt       DateTime @default(now())
  projectId       String?
  taskId          String?
  conversationId  String?
  userId          String
}
